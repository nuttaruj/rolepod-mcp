{
  "name": "@rolepod/uiproof",
  "version": "0.6.0",
  "description": "Multi-platform UI/mobile automation for AI agents — MCP server + shipped skills.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "ui-automation",
    "claude-code",
    "rolepod"
  ],
  "homepage": "https://github.com/nuttaruj/rolepod-uiproof",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuttaruj/rolepod-uiproof.git"
  },
  "license": "MIT",
  "author": "nuttaruj",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "rolepod-uiproof": "dist/bin/rolepod-uiproof.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".codex-plugin/",
    ".cursor/",
    ".agents/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY.md",
    "UPSTREAM_TRACKING.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup && npm run build:schemas",
    "build:schemas": "node scripts/export-schemas.mjs",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "smoke:mcp": "node tests/smoke/mcp_handshake.mjs",
    "start": "node dist/bin/rolepod-uiproof.js"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.8.0",
    "js-yaml": "^4.1.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@wdio/types": "^9.27.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "zod-to-json-schema": "^3.25.2"
  },
  "optionalDependencies": {
    "webdriverio": "^9.27.1"
  }
}
